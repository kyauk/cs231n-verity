# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=meta/llama-3.1-70b-instruct
NVIDIA_VISION_MODEL_ID=meta/llama-3.2-90b-vision-instruct
NVIDIA_EMBEDDING_MODEL_ID=nvidia/nv-dinov2

# OpenAI (fallback/auxiliary)
OPENAI_API_KEY=

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=verity
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/verity

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@verity.local
PGADMIN_DEFAULT_PASSWORD=admin

# nuPlan / discovery pipeline
NUPLAN_DATA_ROOT=/data/nuplan
S3_NUPLAN_BUCKET=verity-nuplan-raw
S3_NUPLAN_PREFIX=nuplan-v1.1/sensor_blobs
S3_NUPLAN_DB_PREFIX=mini-split/data/cache/
S3_NUPLAN_CAMERA_PREFIX_ROOT=camera_0/nuplan-v1.1_mini_camera_0
SYNC_TOLERANCE_US=50000
MIN_COMPLETE_TICK_RATE=0.9

# Embedding stage (encoder-agnostic pipeline contract)
SCENE_ENCODER_BACKEND=fake
SCENE_EMBEDDING_DIM=2048

# NIM containers (self-hosted, requires GPU + NGC_API_KEY)
# Start both with: docker compose --profile gpu up
#
# Switch between hosted and self-hosted by changing NVIDIA_BASE_URL:
#   hosted NIM:    NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
#   self-hosted:   NVIDIA_BASE_URL=http://localhost:8081/v1
#
# Check available model_id after container starts: curl http://localhost:8081/v1/models
COSMOS_EMBED1_URL=http://localhost:8080
COSMOS_REASON2_URL=http://localhost:8081
NGC_API_KEY=

# Scorer NIM text model (Module 4 plausibility + difficulty arms)
SCORER_NIM_MODEL_ID=meta/llama-3.1-70b-instruct

# NIM client timeout (seconds). Applies to both CosmosReason2Client (Encoder)
# and NIMTextClient (Scorer). Default 600 s = 10 min. Prevents a stuck NIM
# call from hanging a ThreadPoolExecutor worker indefinitely.
NVIDIA_NIM_TIMEOUT_SECONDS=600

# ---------------------------------------------------------------------------
# Module 7: Dev Dashboard (private operator-facing eval surface)
#
# The server refuses to start unless VERITY_DEV_MODE=1. Tabs in the
# frontend only render if NEXT_PUBLIC_DEV_DASHBOARD_URL is set at build.
# Run: VERITY_DEV_MODE=1 \
#      DEV_DASHBOARD_BUCKET_URI=gs://your-bucket/verity \
#      uvicorn pipeline.modules.dev_dashboard.server:app --port 8002
# ---------------------------------------------------------------------------
VERITY_DEV_MODE=
DEV_DASHBOARD_PORT=8002
DEV_DASHBOARD_ROUNDS_DIR=
DEV_DASHBOARD_BUCKET_URI=
DEV_DASHBOARD_SIGN_AS=

# ---------------------------------------------------------------------------
# GCS signed URLs (read by `pipeline.run analyze`)
#
# v4 signing requires a private-key signer. A user refresh-token from
# `gcloud auth application-default login` CANNOT sign. Pick one:
#
#   1. Service-account key file (simplest for local dev):
#        export GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
#      (do not commit the key. use a key for a *reader* SA only.)
#
#   2. Impersonation (no key on disk; needs IAM):
#        Grant your user `roles/iam.serviceAccountTokenCreator` on a
#        reader SA, then pass `--sign-as reader@project.iam.gserviceaccount.com`
#        to `pipeline.run analyze`.
#
#   3. Public-read bucket (PoC only — never for production data):
#        gsutil iam ch allUsers:objectViewer gs://your-bucket
# ---------------------------------------------------------------------------

# Clustering
UMAP_RANDOM_SEED=42
UMAP_N_COMPONENTS=50
HDBSCAN_MIN_CLUSTER_SIZE=5
GLOSH_THRESHOLD=0.7

# Waymo discovery pipeline (waymo-pipeline/)
# Source data + reconstructed segment videos live in GCS; access uses ADC.
WAYMO_SOURCE_BUCKET=waymo_open_dataset_v_2_0_1
WAYMO_DEST_BUCKET=nvidia-adr-waymo-segment-videos
# Scene-description backend for the agentic analysis stage:
#   nim_vlm (default) -- NVIDIA NIM hosted vision model, no local GPU needed
#   hf                -- local HuggingFace VLM (requires GPU + torch)
COSMOS_DESCRIBE_BACKEND=nim_vlm
DESCRIBE_NIM_MODEL_ID=nvidia/vila
# Multi-agent debate model (NVIDIA NIM text)
DEBATE_NIM_MODEL_ID=meta/llama-3.1-8b-instruct
DEBATE_TEMPERATURE=0.2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
