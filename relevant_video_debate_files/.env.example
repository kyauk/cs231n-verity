# Required for debate stage (NVIDIA NIM text model)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
DEBATE_NIM_MODEL_ID=meta/llama-3.1-8b-instruct
DEBATE_TEMPERATURE=0.2
# Retries for transient NIM 5xx errors during debate actors
DEBATE_NIM_MAX_RETRIES=3

# Required for description stage (local HF model)
# Default is Qwen3-VL-30B-A3B (MoE). Override to a dense variant such as
# Qwen/Qwen3-VL-8B-Instruct or nvidia/Cosmos-Reason2-8B if VRAM is tight.
COSMOS_HF_MODEL_ID=Qwen/Qwen3-VL-30B-A3B-Instruct
COSMOS_HF_MAX_NEW_TOKENS=3200
COSMOS_HF_VIDEO_FPS=8
COSMOS_HF_TORCH_DTYPE=float16
# Optional: int8 / int4 quantization to fit MoE checkpoints on smaller GPUs.
# Requires `pip install bitsandbytes`.
# COSMOS_HF_QUANTIZATION=int4

# Optional upload-runner defaults
WORKSPACE_MAX_NEW_TOKENS=3200
WORKSPACE_DEBATE_ROUNDS=2
WORKSPACE_VIDEO_FPS=8

# ReAct debate engine (Step 1)
REACT_MAX_STEPS_PER_ACTOR=5
REACT_ACTOR_TEMPERATURE=0.3
# Scene Analyst vlm_followup: 0=text-only from prior description (default), 1=reload GPU VLM
REACT_ENABLE_VLM_FOLLOWUP=0
REACT_VLM_FOLLOWUP_MAX_NEW_TOKENS=512
